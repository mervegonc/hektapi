# Supabase (anon key is public in browser — protect data with RLS policies)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin access (comma-separated emails)
ADMIN_EMAILS=

# Email (Resend) — server only, never use NEXT_PUBLIC_
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@hektapi.com.tr
QUOTE_NOTIFICATION_EMAIL=info@hektapi.com.tr

# Telegram notifications — server only
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API rate limits (requests per hour)
RATE_LIMIT_TEKLIF_PER_HOUR=5
RATE_LIMIT_YANITLA_PER_HOUR=20

# Optional: enable mobile debug console in production (not recommended)
# NEXT_PUBLIC_ENABLE_ERUDA=true
